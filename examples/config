# dcnr configuration
# Installed to: ~/.config/dcnr/config
# Edit this file to match your setup, then run: dcnr build

# ── Image ─────────────────────────────────────────────────────────────────────

# Name of the Docker image dcnr uses for new containers.
# Run 'dcnr build' to build it from the Dockerfile in this repo.
DCNR_IMAGE="dcnr-base"

# ── Container defaults ────────────────────────────────────────────────────────

# Username inside containers (must match Dockerfile ARG USERNAME).
DCNR_USERNAME="dev"

# Shell to open when running 'dcnr shell <name>'.
DCNR_SHELL="/usr/bin/zsh"

# ── Host mounts ───────────────────────────────────────────────────────────────
#
# Paths on your Mac that are mounted into each new container.
# Format: "host_path:container_path" or "host_path:container_path:ro"
#
# Security notes:
#   - Mounting ~/.config exposes only that directory. Docker bind mounts are
#     scoped exactly to the specified path — a container cannot traverse up
#     from /home/dev/.config to reach anything else on the host filesystem.
#   - Plugin/data dirs (e.g. ~/.local/share/nvim) are NOT mounted; they live
#     inside each container for supply chain isolation between containers.
#   - Do NOT mount ~/.ssh. Private keys inside a container are a liability —
#     use SSH agent forwarding instead (see SSH section below).
#
# Paths that don't exist on the host are silently skipped.

DCNR_MOUNTS=(
    # All XDG config (neovim, tmux, yazi, etc.) — read-only.
    # To update lazy-lock.json or other generated config files, do so from
    # your host and the change will be visible in all containers immediately.
    "$HOME/.config:/home/dev/.config:ro"

    # Tmux config if stored outside XDG (pick one or both as needed)
    "$HOME/.tmux.conf:/home/dev/.tmux.conf:ro"

    # Git identity
    "$HOME/.gitconfig:/home/dev/.gitconfig:ro"
)

# ── Shell rc files ────────────────────────────────────────────────────────────
#
# The host's ~/.zshrc and ~/.zprofile are intentionally NOT mounted. They
# usually contain host-specific setup (Homebrew PATHs, 'eval' calls for
# tools that aren't installed in the container, powerlevel10k instant
# prompt, macOS-only aliases, etc.) that breaks or makes no sense inside a
# Linux container.
#
# Instead, put dcnr-specific shell rc files in your dcnr config directory:
#
#   ~/.config/dcnr/zshrc        -> /home/dev/.zshrc
#   ~/.config/dcnr/zprofile     -> /home/dev/.zprofile
#   ~/.config/dcnr/bashrc       -> /home/dev/.bashrc
#   ~/.config/dcnr/bash_profile -> /home/dev/.bash_profile
#   ~/.config/dcnr/profile      -> /home/dev/.profile
#
# Any of these that exist are copied into each new container at creation
# time (after the container is created, before the install script runs).
# They are container-local and writable, so the install script can append
# to them (e.g. the ssh-agent bootstrap). An example lives at
# examples/zshrc in this repo — symlink or copy it:
#
#   cp examples/zshrc ~/.config/dcnr/zshrc

# ── SSH agent forwarding ──────────────────────────────────────────────────────
#
# Do NOT mount ~/.ssh — private keys inside a container are a security risk.
# Use SSH agent forwarding instead so containers can authenticate (e.g. git
# over SSH) without ever seeing your private keys.
#
# On macOS with OrbStack, agent forwarding works automatically.
# With Docker Desktop, add to DCNR_ENV and DCNR_MOUNTS:
#
#   DCNR_ENV+=("SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock")
#   DCNR_MOUNTS+=("/run/host-services/ssh-auth.sock:/run/host-services/ssh-auth.sock:ro")

# ── Environment variables ─────────────────────────────────────────────────────

DCNR_ENV=(
    "TERM=xterm-256color"
    "COLORTERM=truecolor"
)
